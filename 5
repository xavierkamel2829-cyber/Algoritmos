while True:
    def calcular_calorias_y_suplementos():
        print("--- BIENVENIDO A TU CALCULADORA NUTRICIONAL ---")
        
        # 1. Recopilación de datos básicos
        genero = input("¿Cuál es tu género? (hombre/mujer): ").strip().lower()
        peso = float(input("¿Cuál es tu peso en kg? (ej. 75): "))
        altura = float(input("¿Cuál es tu altura en cm? (ej. 175): "))
        edad = int(input("¿Cuál es tu edad en años?: "))
        
        # 2. Cálculo de la Tasa Metabólica Basal (Mifflin-St Jeor)
        if genero == "hombre":
            tmb = (10 * peso) + (6.25 * altura) - (5 * edad) + 5
        elif genero == "mujer":
            tmb = (10 * peso) + (6.25 * altura) - (5 * edad) - 161
        else:
            print("Género no reconocido. Se usará el promedio.")
            tmb = (10 * peso) + (6.25 * altura) - (5 * edad) - 78

        # 3. Factor de actividad física
        print("\nSelecciona tu nivel de actividad física diaria:")
        print("1. Sedentario (poco o nada de ejercicio)")
        print("2. Ligero (ejercicio ligero 1-3 días/semana)")
        print("3. Moderado (ejercicio moderado 3-5 días/semana)")
        print("4. Intenso (ejercicio fuerte 6-7 días/semana)")
        actividad_opcion = input("Elige una opción (1-4): ").strip()
        
        factores = {"1": 1.2, "2": 1.375, "3": 1.55, "4": 1.725}
        factor = factores.get(actividad_opcion, 1.2) # Por defecto sedentario si hay error
        
        calorias_mantenimiento = tmb * factor
        
        # 4. Selección de objetivo (Volumen o Definición)
        print("\n¿Cuál es tu objetivo actual?")
        print("1. Volumen (Ganar masa muscular)")
        print("2. Definición (Perder grasa)")
        objetivo = input("Elige una opción (1-2): ").strip()
        
        print("\n" + "="*40)
        print("--- RESULTADOS ENERGÉTICOS ---")
        print(f"Tu metabolismo basal (TMB) es: {round(tmb)} kcal.")
        print(f"Tus calorías de mantenimiento son: {round(calorias_mantenimiento)} kcal.")
        
        if objetivo == "1":
            # Superávit calórico recomendado (300 a 500 kcal extra)
            calorias_objetivo = calorias_mantenimiento + 400
            print(f"Para OBJETIVO VOLUMEN debes consumir diariamente: {round(calorias_objetivo)} kcal.")
        elif objetivo == "2":
            # Déficit calórico recomendado (300 a 500 kcal menos)
            calorias_objetivo = calorias_mantenimiento - 500
            print(f"Para OBJETIVO DEFINICIÓN debes consumir diariamente: {round(calorias_objetivo)} kcal.")
        else:
            print("Opción de objetivo no válida.")
            
        print("="*40)

        # 5. Sección de Suplementos
        print("\n--- SECCIÓN DE SUPLEMENTOS ---")
        print("¿Te interesa consumir alguno de estos suplementos? (Sola una opción)")
        print("1. Creatina")
        print("2. Proteína en polvo")
        print("3. Ninguno")
        suplemento = input("Elige una opción (1-3): ").strip()
        
        print("\n--- RECOMENDACIÓN DE SUPLEMENTACIÓN ---")
        if suplemento == "1":
            # Dosis estándar de creatina: 0.1g por kg de peso corporal
            gramos_creatina = peso * 0.1
            print(f"-> Creatina: Debes tomar aproximadamente {round(gramos_creatina, 1)} gramos al día.")
            print("Nota: Recuerda tomarla diariamente, idealmente cerca de tu entrenamiento.")
            
        elif suplemento == "2":
            # Proteína: En definición se necesita un poco más para preservar músculo
            # Hombres y mujeres varían ligeramente, pero el peso y el objetivo dictan la pauta principal
            if objetivo == "2": # Definición
                gramos_proteina_total = peso * 2.2
                rango = "2.0 - 2.4 g/kg"
            else: # Volumen o mantenimiento
                gramos_proteina_total = peso * 1.8
                rango = "1.6 - 2.0 g/kg"
                
            # Asumiendo que un scoop/batido aporta unos 25g de proteína para complementar su dieta diaria
            print(f"-> Proteína total diaria requerida en tu dieta: {round(gramos_proteina_total)} gramos (basado en un rango de {rango}).")
            print("-> Un batido de proteína en polvo estándar (1 scoop) te aportará unos 25 gramos de este total.")
            
        elif suplemento == "3":
            print("¡Perfecto! Una alimentación equilibrada puede cubrir todas tus necesidades.")
        else:
            print("Opción de suplemento no válida.")
        print("="*40)

    # Ejecutar la función
    calcular_calorias_y_suplementos()
    continuar=input("quieles continual?(s/n): ").lower
    if continuar!='s':
        break